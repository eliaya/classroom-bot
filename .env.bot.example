# Discord Bot Secrets
# Paste your Bot Token from the Discord Developer Portal
DISCORD_BOT_TOKEN="your_discord_bot_token_here"

# Set false for local compose when you want the container to stay up without connecting to Discord.
BOT_ENABLED=true

# Sync Configuration (interval in minutes, default is 10)
SYNC_INTERVAL_MINUTES=10

# Database URI (SQLite used inside the container volume)
DATABASE_URL="sqlite+aiosqlite:////app/data/classroom_sync.db"

# Google Credentials Paths
# These are mounted within the docker container at /app/credentials/
GOOGLE_CLIENT_SECRET_FILE="/app/credentials/client_secret.json"
GOOGLE_TOKEN_FILE="/app/credentials/token.json"

# Logging Level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL="INFO"
# Emit structured JSON logs (with timestamp + job_id) instead of plain text.
LOG_JSON=false

# API / Web admin (FastAPI + shadcn-admin UI)
ADMIN_API_TOKEN=""
API_HOST="0.0.0.0"
API_PORT=8000
CLASSROOM_SYNC_INTERVAL_MINUTES=30
API_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:8080"

# Classwork attachment content sync.
# Downloads Drive attachments (PDF/Excel) and exports Google Docs/Sheets during
# each course sync, storing files on disk with metadata in the DB. Requires the
# optional Drive scope — re-run `python src/scripts/setup_google_auth.py` to grant
# it. Without the scope, downloads are skipped and Classroom sync is unaffected.
ATTACHMENT_SYNC_ENABLED=true
ATTACHMENT_STORAGE_DIR="/app/data/attachments"
ATTACHMENT_MAX_BYTES=52428800
ATTACHMENT_DOWNLOAD_RETRIES=2

# Gmail Incoming Notification Placeholders (reserved for next phase)
# These values are currently accepted by configuration but not used by runtime code.
GMAIL_NOTIFICATIONS_ENABLED=false
GMAIL_POLL_INTERVAL_MINUTES=5
GMAIL_LABEL_FILTER="INBOX"
GMAIL_DISCORD_CHANNEL_ID=""
GOOGLE_GMAIL_TOKEN_FILE="/app/credentials/gmail_token.json"
HTTP_PORT=
